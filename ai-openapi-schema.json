{
  "openapi": "3.1.0",
  "info": {
    "title": "TaskAssist AI API",
    "description": "API endpoints designed for Claude / OpenAI assistants to interact with the TaskAssist platform.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://beta.timepro.in/api/ai",
      "description": "TaskAssist AI API Server"
    }
  ],
  "paths": {
    "/reseller-balance": {
      "get": {
        "operationId": "getResellerBalance",
        "summary": "Get Reseller Balance",
        "description": "Retrieves the current real-time wallet balance from ResellerClub.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response containing the reseller account balance.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "balance": {
                      "type": "number",
                      "description": "The current wallet balance from ResellerClub."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid or missing Bearer token."
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
